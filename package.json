{
  "name": "solace-message-client",
  "scripts": {
    "before-push": "run-s build lint test:headless",
    "build": "run-s **:*:build **:*:typedoc",
    "lint": "run-p **:*:lint",
    "test": "run-s **:*:test",
    "test:headless": "cross-env HEADLESS=true run-p \"**:*:test -- {@}\" --",
    "start": "run-s solace-message-client-testing-app:serve",
    "changelog": "run-p changelog:*",
    "changelog:fullest": "conventional-changelog -k projects/solace-message-client/package.json -p angular -i CHANGELOG.md -s && markdown-include docs/site/changelog/changelog.template.json",
    "changelog:latest": "conventional-changelog -k projects/solace-message-client/package.json -p angular -o CHANGELOG_LATEST.md",

    "copy-src": "run-p copy-src:*",
    "copy-src:scion-toolkit": "cpx --clean --watch --verbose ../scion-toolkit/projects/scion/toolkit/** ./src-lib/@scion/toolkit",
    "copy-src:scion-components": "cpx --clean --watch --verbose ../scion-toolkit/projects/scion/components/** ./src-lib/@scion/components",

    "solace-message-client:lint": "ng lint solace-message-client",
    "solace-message-client:test": "ng test solace-message-client",
    "solace-message-client:build": "ng build --configuration production solace-message-client",
    "solace-message-client:typedoc": "typedoc --tsconfig projects/solace-message-client/tsconfig.lib.prod.typedoc.json --favicon resources/branding/favicon.ico",

    "solace-message-client-testing-app:serve": "ng serve solace-message-client-testing-app",
    "solace-message-client-testing-app:lint": "ng lint solace-message-client-testing-app",
    "solace-message-client-testing-app:build": "ng build --configuration=production solace-message-client-testing-app"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "20.0.2",
    "@angular/cdk": "20.0.2",
    "@angular/common": "20.0.2",
    "@angular/compiler": "20.0.2",
    "@angular/core": "20.0.2",
    "@angular/forms": "20.0.2",
    "@angular/material": "20.0.2",
    "@angular/platform-browser": "20.0.2",
    "@angular/router": "20.0.2",
    "@scion/components": "20.0.0",
    "@scion/toolkit": "2.0.0",
    "pako": "2.1.0",
    "rxjs": "7.8.2",
    "solclientjs": "10.18.0",
    "tslib": "2.8.1",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular/build": "20.0.1",
    "@angular/cli": "20.0.1",
    "@angular/compiler-cli": "20.0.2",
    "@smarttools/eslint-plugin-rxjs": "1.0.20",
    "@stylistic/eslint-plugin": "4.4.1",
    "@types/jasmine": "5.1.8",
    "@types/pako": "2.0.3",
    "angular-eslint": "20.0.0",
    "conventional-changelog-cli": "5.0.0",
    "cpx2": "8.0.0",
    "cross-env": "7.0.3",
    "eslint": "9.28.0",
    "jasmine-core": "5.8.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "markdown-include": "0.4.3",
    "ng-packagr": "20.0.0",
    "npm-run-all2": "8.0.4",
    "puppeteer": "24.10.0",
    "typedoc": "0.28.5",
    "typescript": "5.8.3",
    "typescript-eslint": "8.34.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/solacecommunity/angular-solace-message-client.git"
  }
}
